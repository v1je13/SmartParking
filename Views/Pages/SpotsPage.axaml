<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SmartParking.Views.Pages.SpotsPage">

    <StackPanel Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Парковочные места" FontSize="26" FontWeight="Bold"
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
            <Button Name="BtnAddSpot" Content="+ Добавить место" 
                    Background="#89B4FA" Foreground="#1E1E2E" FontSize="13"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnAddSpot_Click"/>
        </StackPanel>

        <!-- Фильтр по зонам -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Зона:" Foreground="#CDD6F4" VerticalAlignment="Center"/>
            <ComboBox Name="CmbFilterZone" Width="250" Background="#313244" Foreground="#CDD6F4"
                      SelectionChanged="CmbFilterZone_SelectionChanged">
                <ComboBoxItem>Все зоны</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Таблица мест -->
        <Border Background="#313244" CornerRadius="12" Padding="20">
            <DataGrid Name="GridSpots"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      Background="Transparent"
                      Foreground="#CDD6F4"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#45475A"
                      BorderThickness="1"
                      MaxHeight="500">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Зона" Binding="{Binding Zone.Name}" Width="150"/>
                    <DataGridTextColumn Header="№ Места" Binding="{Binding SpotNumber}" Width="100"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding SpotType}" Width="120"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                    <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки действий -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Name="BtnEditSpot" Content="✏ Редактировать"
                    Background="#45475A" Foreground="#CDD6F4" FontSize="12"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnEditSpot_Click"/>
            <Button Name="BtnDeleteSpot" Content="🗑 Удалить"
                    Background="#F38BA8" Foreground="#1E1E2E" FontSize="12"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnDeleteSpot_Click"/>
            <Button Name="BtnMarkFree" Content="✅ Отметить свободным"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontSize="12"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnMarkFree_Click"/>
            <Button Name="BtnMarkRepair" Content="🔧 На ремонт"
                    Background="#FAB387" Foreground="#1E1E2E" FontSize="12"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnMarkRepair_Click"/>
            <Button Name="BtnRefresh" Content="🔄 Обновить"
                    Background="#45475A" Foreground="#CDD6F4" FontSize="12"
                    Padding="12,8" CornerRadius="6" Cursor="Hand"
                    Click="BtnRefresh_Click"/>
        </StackPanel>

        <!-- Форма для редактирования -->
        <Border Background="#313244" CornerRadius="12" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock Text="Редактировать место" FontSize="14" FontWeight="Bold"
                           Foreground="#CDD6F4"/>

                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto">
                    <!-- Зона -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Зона:" 
                               Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Name="CmbZone" Grid.Column="1" Grid.Row="0"
                              Background="#1E1E2E" Foreground="#CDD6F4" Padding="8"
                              CornerRadius="4" Margin="0,0,24,0"/>

                    <!-- Номер места -->
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="№ Места:" 
                               Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox Name="TxtSpotNumber" Grid.Column="3" Grid.Row="0"
                             Background="#1E1E2E" Foreground="#CDD6F4" Padding="8"
                             CornerRadius="4"/>

                    <!-- Тип -->
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Тип:" 
                               Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Name="CmbSpotType" Grid.Column="1" Grid.Row="1"
                              Background="#1E1E2E" Foreground="#CDD6F4" Padding="8"
                              CornerRadius="4" Margin="0,0,24,0">
                        <ComboBoxItem>Обычное</ComboBoxItem>
                        <ComboBoxItem>Для инвалидов</ComboBoxItem>
                        <ComboBoxItem>Для грузовых</ComboBoxItem>
                    </ComboBox>

                    <!-- Статус -->
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="Статус:" 
                               Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Name="CmbStatus" Grid.Column="3" Grid.Row="1"
                              Background="#1E1E2E" Foreground="#CDD6F4" Padding="8"
                              CornerRadius="4">
                        <ComboBoxItem>Free</ComboBoxItem>
                        <ComboBoxItem>Occupied</ComboBoxItem>
                        <ComboBoxItem>Repair</ComboBoxItem>
                    </ComboBox>

                    <!-- Кнопки -->
                    <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="4"
                                Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Name="BtnSaveSpot" Content="💾 Сохранить"
                                Background="#A6E3A1" Foreground="#1E1E2E" FontSize="12"
                                Padding="12,8" CornerRadius="6" Cursor="Hand"
                                Click="BtnSaveSpot_Click"/>
                        <Button Name="BtnCancelEdit" Content="✕ Отмена"
                                Background="#45475A" Foreground="#CDD6F4" FontSize="12"
                                Padding="12,8" CornerRadius="6" Cursor="Hand"
                                Click="BtnCancelEdit_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
